# App
APP_NAME=GazePilot API
APP_ENV=dev
APP_HOST=0.0.0.0
APP_PORT=8000
API_PREFIX=/api/v1

# Postgres
DATABASE_URL=postgresql+psycopg://gazepilot:gazepilot@localhost:5432/gazepilot

# WebSocket
WS_MAX_CLIENTS=200

# Queue / ingest
FRAME_QUEUE_MODE=memory
FRAME_QUEUE_MAXSIZE=256
FRAME_MAX_FPS=8
FRAME_MAX_BYTES=350000

# Redis (produção opcional)
REDIS_ENABLED=false
REDIS_URL=redis://localhost:6379/0
REDIS_QUEUE_NAME=gazepilot:frames

# Command engine
COMMAND_EMA_ALPHA=0.35
COMMAND_DWELL_MS=400
COMMAND_COOLDOWN_MS=1000
YAW_THRESHOLD_DEG=20
PITCH_THRESHOLD_DEG=15

# Device defaults
DEFAULT_STREAM_FPS=6
DEFAULT_JPEG_QUALITY=10
DEFAULT_RESOLUTION=QVGA

# CV pipeline
CV_BACKEND=auto
CV_MEDIAPIPE_MODEL_PATH=models/face_landmarker.task
CV_MIN_FACE_DETECTION_CONFIDENCE=0.5
CV_MIN_FACE_PRESENCE_CONFIDENCE=0.5
CV_MIN_TRACKING_CONFIDENCE=0.5
CV_BLINK_EAR_THRESHOLD=0.19

# Dev convenience (produção: prefira migrations Alembic)
AUTO_CREATE_TABLES=true
