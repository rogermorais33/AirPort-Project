# URL base do backend FastAPI (sem barra final)
BACKEND_API_BASE_URL=http://localhost:8000

# Caminho interno de consumo via proxy local do Next.js
NEXT_PUBLIC_DASHBOARD_API_ROOT=/api/proxy/v1

# Base HTTP pública do backend para fallback no cliente
NEXT_PUBLIC_BACKEND_API_BASE_URL=http://localhost:8000

# Base WS explícita (recomendado)
# Local: ws://localhost:8000
# Produção: wss://<backend>.onrender.com
NEXT_PUBLIC_BACKEND_WS_BASE_URL=ws://localhost:8000
