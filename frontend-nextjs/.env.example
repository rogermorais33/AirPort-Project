# URL base da API FastAPI (sem barra final)
BACKEND_API_BASE_URL=http://localhost:8000

# Caminho interno de consumo no frontend (mantenha se usar o proxy local)
NEXT_PUBLIC_DASHBOARD_API_ROOT=/api/proxy/v1

# Base HTTP do backend para o cliente (opcional, usada para inferir WebSocket)
NEXT_PUBLIC_BACKEND_API_BASE_URL=http://localhost:8000

# Base WebSocket do backend (recomendado definir explicitamente)
# Local: ws://localhost:8000
# Produção Render HTTPS: wss://<seu-servico>.onrender.com
NEXT_PUBLIC_BACKEND_WS_BASE_URL=ws://localhost:8000

# Device padrão ao abrir dashboard
NEXT_PUBLIC_DEFAULT_DEVICE_ID=esp32-wokwi-001
