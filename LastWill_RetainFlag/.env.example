MQTT_BROKER_URL=mqtt://127.0.0.1:1883
MQTT_BROKER_PORT=1883
MQTT_BROKER_HOST=127.0.0.1

# true = sessao limpa a cada conexao.
# false = sessao persistente no broker, desde que o clientId seja fixo.
MQTT_CLEAN=true

# Use clientIds fixos quando testar MQTT_CLEAN=false.
MQTT_PUB_CLIENT_ID=pub-terminal-a-fixo
MQTT_SUB_CLIENT_ID=sub-lwt-retain-fixo
